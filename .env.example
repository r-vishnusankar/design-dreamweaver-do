# Studio (The Virtual Invite marketing site)
# Copy to .env.local for local dev, and set the same keys in Netlify → Environment variables.

# Formspree — create a form at https://formspree.io then paste either:
#   full URL: https://formspree.io/f/xxxxxxxx
#   or just the id: xxxxxxxx
VITE_FORMSPREE_ENDPOINT=

# Optional: override live sample invite URLs used in the phone preview
# VITE_SAMPLE_INVITE_URL=
# VITE_SAMPLE_INVITE_URL_SIG=
# VITE_SAMPLE_INVITE_URL_B=
